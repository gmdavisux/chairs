# ── LLM provider ────────────────────────────────────────────────────────────
# Option A: Standard OpenAI API (default)
OPENAI_API_KEY=your_openai_api_key_here

# Option B: GitHub Models endpoint (routes through your Copilot subscription)
# Set GITHUB_MODELS=1 AND provide your GitHub PAT as GITHUB_TOKEN.
# When GITHUB_MODELS=1, OPENAI_API_KEY is not required.
GITHUB_MODELS=0
GITHUB_TOKEN=your_github_personal_access_token_here

# Override the primary model (default: gpt-4o).
# FURNITURE_MODEL=gpt-4o

# GitHub Models fallback chain (comma-separated model IDs, GitHub Models only).
# Each ID has its own independent per-day quota bucket ("UserByModelByDay").
# On rate-limit, the pipeline advances to the next model immediately — no waiting.
# Default chain when GITHUB_MODELS=1: gpt-4o, gpt-4o-mini, Meta-Llama-3.3-70B-Instruct
# FURNITURE_MODEL_FALLBACKS=gpt-4o,gpt-4o-mini,Meta-Llama-3.3-70B-Instruct

# ── Web search ───────────────────────────────────────────────────────────────
# Required for the Researcher agent. Get a free key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ── Image pipeline ───────────────────────────────────────────────────────────
# Provider priority in furniture_agent.py:
#   - google: Gemini first, then FAL fallback (recommended)
#   - fal: FAL only unless OPENAI fallback is explicitly enabled below
#   - openai: OpenAI image API only
FURNITURE_IMAGE_PROVIDER=google

# Google Gemini image generation
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Default FLUX path via fal.ai
FAL_KEY=your_fal_api_key_here
FURNITURE_IMAGE_MODEL=fal-ai/flux/dev

# Optional OpenAI image fallback (disabled by default)
# Set to 1 only if you intentionally want paid OpenAI fallback.
FURNITURE_ALLOW_OPENAI_FALLBACK=0
# OPENAI_IMAGE_MODEL=gpt-image-1

# Quality and budget controls (planned)
FURNITURE_IMAGE_SIZE=1024x1024
FURNITURE_IMAGE_MAX_PER_PAGE=4
FURNITURE_IMAGE_BUDGET_USD=0.20
FURNITURE_IMAGE_TIMEOUT_SECONDS=60

# Run behavior controls (planned)
FURNITURE_AUTO_COMMIT=0
