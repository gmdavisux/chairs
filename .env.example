# ── LLM provider ────────────────────────────────────────────────────────────
# Option A: Standard OpenAI API (default)
OPENAI_API_KEY=your_openai_api_key_here

# Option B: GitHub Models endpoint (routes through your Copilot subscription)
# Set GITHUB_MODELS=1 AND provide your GitHub PAT as GITHUB_TOKEN.
# When GITHUB_MODELS=1, OPENAI_API_KEY is not required.
GITHUB_MODELS=0
GITHUB_TOKEN=your_github_personal_access_token_here

# Override the default model (default: gpt-5.4-mini, 0.33x cost tier)
# FURNITURE_MODEL=gpt-5.4-mini

# ── Web search ───────────────────────────────────────────────────────────────
# Required for the Researcher agent. Get a free key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ── Image pipeline (planned automation contract) ────────────────────────────
# Provider selection is designed to be provider-agnostic.
# Supported values (planned): fal, openai
FURNITURE_IMAGE_PROVIDER=fal

# Default FLUX path via fal.ai
FAL_KEY=your_fal_api_key_here
FURNITURE_IMAGE_MODEL=flux

# Optional OpenAI image fallback
# OPENAI_IMAGE_MODEL=gpt-image-1

# Quality and budget controls (planned)
FURNITURE_IMAGE_SIZE=1024x1024
FURNITURE_IMAGE_MAX_PER_PAGE=4
FURNITURE_IMAGE_BUDGET_USD=0.20
FURNITURE_IMAGE_TIMEOUT_SECONDS=60

# Run behavior controls (planned)
FURNITURE_AUTO_COMMIT=0
