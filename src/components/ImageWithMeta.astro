---
interface ImageRecord {
  id: string;
  src: string;
  alt: string;
  altStatus?: 'proposed' | 'actual';
  caption?: string;
  source?: string;
  license?: string;
  origin?: string;
}

interface Props {
  id?: string;
  images?: ImageRecord[];
  entryImages?: ImageRecord[];
  src?: string;
  alt?: string;
  altStatus?: 'proposed' | 'actual';
  caption?: string;
  source?: string;
  license?: string;
  origin?: string;
}

const {
  id,
  images,
  entryImages,
  src,
  alt,
  altStatus,
  caption,
  source,
  license,
  origin,
} = Astro.props;

const imageRegistry = images ?? entryImages ?? [];

const fromRegistry = id ? imageRegistry.find((item) => item.id === id) : undefined;
const resolvedSrc = src || fromRegistry?.src;
const resolvedAlt = alt || fromRegistry?.alt || 'Proposed image placeholder';
const resolvedAltStatus = altStatus || fromRegistry?.altStatus || 'proposed';
const resolvedCaption = caption || fromRegistry?.caption;
const resolvedSource = source || fromRegistry?.source || 'TBD';
const resolvedLicense = license || fromRegistry?.license || 'unknown';
const resolvedOrigin = origin || fromRegistry?.origin || 'placeholder';
---

{resolvedSrc && (
  <figure class="image-with-meta">
    <div class="img-wrapper" title={resolvedSource}>
      <img src={resolvedSrc} alt={resolvedAlt} loading="lazy" decoding="async" />
    </div>
    {resolvedCaption && (
      <figcaption>
        {resolvedCaption}
      </figcaption>
    )}
  </figure>
)}

<style>
  .image-with-meta {
    margin: 2rem 0;
  }

  .img-wrapper {
    position: relative;
  }

  .img-wrapper img {
    width: 100%;
    display: block;
    border-radius: 10px;
    box-shadow: var(--box-shadow);
  }

  .img-wrapper::after {
    content: attr(title);
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.5rem 0.75rem;
    background: rgba(0, 0, 0, 0.2);
    color: white;
    font-size: 0.75rem;
    line-height: 1.4;
    border-radius: 0 0 10px 10px;
    pointer-events: none;
    backdrop-filter: blur(2px);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .img-wrapper:hover::after {
    opacity: 1;
    transition: opacity 0.35s ease 0.5s;
  }

  .image-with-meta figcaption {
    margin-top: 0.75rem;
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgb(var(--gray-dark));
    font-style: italic;
  }
</style>
