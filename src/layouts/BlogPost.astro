---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	prevPost?: CollectionEntry<'blog'> | null;
	nextPost?: CollectionEntry<'blog'> | null;
	relatedByDesigner?: CollectionEntry<'blog'>[];
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	heroImageAlt,
	heroImageAltStatus,
	heroImageCaption,
	heroImageSource,
	heroImageLicense,
	heroImageOrigin,
	designer,
	designerBio,
	designerYears,
	designerImage,
	era,
	category,
	manufacturer,
	yearDesigned,
	keywords,
	prevPost,
	nextPost,
	relatedByDesigner,
} = Astro.props;

const heroAlt =
	heroImageAlt ||
	`Proposed hero image for ${title}`;
const heroSourceLabel = heroImageSource || 'TBD';
const heroLicenseLabel = heroImageLicense || 'unknown';
const heroOriginLabel = heroImageOrigin || 'placeholder';
const heroAltStatusLabel = heroImageAltStatus || 'proposed';
const showHeroMetadata =
	Boolean(heroImageCaption) ||
	Boolean(heroImageSource) ||
	Boolean(heroImageLicense) ||
	Boolean(heroImageOrigin) ||
	Boolean(heroImageAlt);

// ── JSON-LD structured data (schema.org @graph) ───────────────────────────────
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const heroImageAbsolute = heroImage ? new URL(heroImage, Astro.site).href : undefined;

// Parse designer birth/death years from strings like "1902–1971" or "1902-1971"
let designerBirthDate: string | undefined;
let designerDeathDate: string | undefined;
if (designerYears) {
	const yearMatch = designerYears.match(/(\d{4})[–\-](\d{4})/);
	if (yearMatch) {
		designerBirthDate = yearMatch[1];
		designerDeathDate = yearMatch[2];
	}
}

const jsonLdGraph: object[] = [];

// Article node
const articleNode: Record<string, unknown> = {
	'@type': 'Article',
	'@id': `${canonicalURL}#article`,
	headline: title,
	description,
	url: canonicalURL.href,
	datePublished: pubDate.toISOString(),
	...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
	...(heroImageAbsolute ? { image: heroImageAbsolute } : {}),
	author: { '@type': 'Organization', name: SITE_TITLE },
	publisher: { '@type': 'Organization', name: SITE_TITLE },
	...(keywords && keywords.length > 0 ? { keywords: keywords.join(', ') } : {}),
	speakable: {
		'@type': 'SpeakableSpecification',
		cssSelector: ['.prose > p:first-of-type'],
	},
};
if (designer) {
	articleNode.about = { '@id': `${canonicalURL}#product` };
}
jsonLdGraph.push(articleNode);

// Product node
if (title) {
	const productNode: Record<string, unknown> = {
		'@type': 'Product',
		'@id': `${canonicalURL}#product`,
		name: title,
		description,
		category: category || 'Furniture',
		...(heroImageAbsolute ? { image: heroImageAbsolute } : {}),
		...(yearDesigned ? { productionDate: String(yearDesigned) } : {}),
	};
	if (designer) {
		productNode.brand = { '@id': `${canonicalURL}#designer` };
	}
	if (manufacturer) {
		productNode.manufacturer = { '@type': 'Organization', name: manufacturer };
	}
	jsonLdGraph.push(productNode);
}

// Person node (designer)
if (designer) {
	const personNode: Record<string, unknown> = {
		'@type': 'Person',
		'@id': `${canonicalURL}#designer`,
		name: designer,
		...(designerBio ? { description: designerBio } : {}),
		...(designerBirthDate ? { birthDate: designerBirthDate } : {}),
		...(designerDeathDate ? { deathDate: designerDeathDate } : {}),
	};
	jsonLdGraph.push(personNode);
}

// BreadcrumbList node
jsonLdGraph.push({
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
		{ '@type': 'ListItem', position: 2, name: 'Blog', item: new URL('/blog/', Astro.site).href },
		{ '@type': 'ListItem', position: 3, name: title, item: canonicalURL.href },
	],
});

const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': jsonLdGraph,
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			type="article"
			pubDate={pubDate}
			author={designer}
			keywords={keywords}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		<style>
			/* Override global main width to allow the wider article+sidebar layout */
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0 auto;
				padding: 3em 1em;
			}
			.article-outer {
				max-width: 1120px;
				margin: 0 auto;
			}
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.hero-caption {
				margin: 0.5rem auto 2rem;
				max-width: 1020px;
				text-align: center;
				font-family: "Lato", sans-serif;
				font-size: 0.875rem;
				font-style: italic;
				color: rgb(var(--gray-dark));
				cursor: help;
			}
			/* Two-column grid: prose | sidebar */
			.article-body {
				display: grid;
				grid-template-columns: 1fr;
				gap: 2.5rem;
				align-items: start;
			}
			@media (min-width: 1024px) {
				.article-body {
					grid-template-columns: 1fr 300px;
				}
			}
			.prose {
				min-width: 0; /* prevent grid blowout */
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}

			/* ── Sidebar ─────────────────────────────────────────────────── */
			#post-sidebar {
				position: sticky;
				top: 2rem;
				background: rgba(200, 121, 65, 0.07);
				border: 1px solid rgba(200, 121, 65, 0.18);
				border-top: 3px solid var(--accent);
				border-radius: 6px;
				padding: 1.5rem 1.5rem 1.25rem;
				font-size: 0.875rem;
				line-height: 1.6;
			}
			/* Metadata pill tags */
			.sidebar-meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin-bottom: 1.25rem;
				padding-bottom: 1rem;
				border-bottom: 1px solid rgba(200, 121, 65, 0.2);
			}
			.sidebar-tag {
				font-family: "Lato", sans-serif;
				font-size: 0.62rem;
				font-weight: 700;
				letter-spacing: 0.09em;
				text-transform: uppercase;
				padding: 0.2rem 0.55rem;
				border-radius: 3px;
				background: rgba(200, 121, 65, 0.13);
				color: var(--accent-dark);
			}
			/* Reset global blockquote styles inside the sidebar */
			:global(#post-sidebar blockquote) {
				border-left: none;
				padding: 0;
				margin: 0;
				font-size: 0.875rem;
				font-style: normal;
				font-family: "Playfair Display", Georgia, serif;
				color: rgb(var(--gray-dark));
			}
			/* Section headings: **Meet the Designer**, **Related Chairs** */
			:global(#post-sidebar blockquote p > strong:only-child),
			:global(#post-sidebar blockquote > p > strong) {
				display: block;
				font-family: "Lato", sans-serif;
				font-size: 0.62rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--accent);
				margin: 1.1rem 0 0.45rem;
				padding-bottom: 0.3rem;
				border-bottom: 1px solid rgba(200, 121, 65, 0.22);
			}
			:global(#post-sidebar blockquote > p:first-child > strong) {
				margin-top: 0;
			}
			:global(#post-sidebar blockquote p) {
				margin-bottom: 0.5rem;
				font-size: 0.875rem;
				line-height: 1.55;
			}
			/* Related chairs list */
			:global(#post-sidebar blockquote ul) {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			:global(#post-sidebar blockquote li) {
				padding: 0.3rem 0;
				border-bottom: 1px solid rgba(155, 135, 118, 0.12);
				font-family: "Playfair Display", Georgia, serif;
				font-size: 0.875rem;
			}
			:global(#post-sidebar blockquote li:last-child) {
				border-bottom: none;
			}
			/* Links in sidebar: warm white, hover to amber */
			:global(#post-sidebar blockquote a) {
				color: rgb(var(--black));
				text-decoration: none;
				transition: color 0.18s ease;
			}
			:global(#post-sidebar blockquote a:hover) {
				color: var(--accent-dark);
			}
			/* *(coming soon)* italic note */
			:global(#post-sidebar blockquote em) {
				font-size: 0.75rem;
				color: rgb(var(--gray));
				font-style: italic;
			}
			
			/* Designer info section */
			.designer-info {
				margin-top: 1.5rem;
				padding-top: 1.5rem;
				border-top: 1px solid rgba(200, 121, 65, 0.2);
			}
			.designer-heading {
				font-family: "Lato", sans-serif;
				font-size: 0.62rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--accent);
				margin: 0 0 0.75rem 0;
				padding-bottom: 0.3rem;
				border-bottom: 1px solid rgba(200, 121, 65, 0.22);
			}
			.designer-image {
				width: 100%;
				border-radius: 6px;
				margin-bottom: 0.75rem;
				box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
			}
			.designer-name {
				font-family: "Playfair Display", Georgia, serif;
				font-size: 1rem;
				font-weight: 600;
				margin: 0 0 0.5rem 0;
				color: rgb(var(--black));
			}
			.designer-years {
				font-size: 0.875rem;
				font-weight: 400;
				color: rgb(var(--gray));
			}
			.designer-bio {
				font-size: 0.875rem;
				line-height: 1.55;
				color: rgb(var(--gray-dark));
				margin: 0;
			}
			.designer-related {
				margin-top: 1.5rem;
				padding-top: 1.5rem;
				border-top: 1px solid rgba(200, 121, 65, 0.2);
			}
			.related-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.related-list li {
				padding: 0.3rem 0;
				border-bottom: 1px solid rgba(155, 135, 118, 0.12);
				font-family: "Playfair Display", Georgia, serif;
				font-size: 0.875rem;
			}
			.related-list li:last-child {
				border-bottom: none;
			}
			.related-list a {
				color: rgb(var(--black));
				text-decoration: none;
				transition: color 0.18s ease;
			}
			.related-list a:hover {
				color: var(--accent-dark);
			}
			
			/* Post Navigation */
			.post-navigation {
				margin: 4rem auto 2rem;
				max-width: 1020px;
				padding-top: 2rem;
				border-top: 2px solid rgba(200, 121, 65, 0.2);
			}
			.nav-wrapper {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.5rem;
			}
			@media (min-width: 768px) {
				.nav-wrapper {
					grid-template-columns: 1fr 1fr;
				}
			}
			.nav-link {
				display: block;
				text-decoration: none;
				border: 1px solid rgba(200, 121, 65, 0.18);
				border-radius: 8px;
				padding: 1.25rem;
				background: rgba(200, 121, 65, 0.05);
				transition: all 0.2s ease;
			}
			.nav-link:hover {
				background: rgba(200, 121, 65, 0.1);
				border-color: var(--accent);
				box-shadow: 0 4px 12px rgba(200, 121, 65, 0.15);
			}
			.nav-link.next {
				text-align: right;
			}
			.nav-direction {
				font-family: "Lato", sans-serif;
				font-size: 0.75rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--accent);
				margin-bottom: 0.75rem;
			}
			.nav-content {
				display: flex;
				align-items: center;
				gap: 1rem;
			}
			.nav-link.next .nav-content {
				flex-direction: row-reverse;
			}
			.nav-thumb {
				width: 80px;
				height: 80px;
				object-fit: cover;
				border-radius: 6px;
				flex-shrink: 0;
			}
			.nav-title {
				font-family: "Playfair Display", Georgia, serif;
				font-size: 1rem;
				font-weight: 600;
				color: rgb(var(--black));
				line-height: 1.3;
			}
			
			/* Affiliate Links Placeholder */
			.affiliate-section {
				margin: 3rem auto 2rem;
				max-width: 1020px;
				padding: 1.5rem;
				background: rgba(200, 121, 65, 0.05);
				border: 1px dashed rgba(200, 121, 65, 0.3);
				border-radius: 8px;
				text-align: center;
				font-size: 0.875rem;
				color: rgb(var(--gray));
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="article-outer">
				<div class="hero-image" title={heroImageSource}>
					{heroImage && <img width={1020} height={510} src={heroImage} alt={heroAlt} />}
					{heroImageCaption && (
						<p class="hero-caption">{heroImageCaption}</p>
					)}
				</div>
				<div class="article-body">
					<div class="prose">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<div class="last-updated-on">
											Last updated on <FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
							<h1>{title}</h1>
							<hr />
						</div>
						<slot />
					</div>
					<aside id="post-sidebar">
						{(designer || era || category) && (
							<div class="sidebar-meta">
								{designer && <span class="sidebar-tag">{designer}</span>}
								{era && <span class="sidebar-tag">{era}</span>}
								{category && <span class="sidebar-tag">{category}</span>}
							</div>
						)}
						{designer && (
							<div class="designer-info">
								<h3 class="designer-heading">Meet the Designer</h3>
								{designerImage && (
									<img src={designerImage} alt={designer} class="designer-image" />
								)}
								<p class="designer-name">
									{designer}
									{designerYears && <span class="designer-years"> ({designerYears})</span>}
								</p>
								{designerBio && <p class="designer-bio">{designerBio}</p>}
							</div>
						)}
						{relatedByDesigner && relatedByDesigner.length > 0 && (
							<div class="designer-related">
								<h3 class="designer-heading">More by {designer}</h3>
								<ul class="related-list">
									{relatedByDesigner.map((p) => (
										<li>
											<a href={`/blog/${p.id}/`}>{p.data.title}</a>
										</li>
									))}
								</ul>
							</div>
						)}
					</aside>
				</div>
				{(prevPost || nextPost) && (
					<nav class="post-navigation">
						<div class="nav-wrapper">
							{prevPost && (
								<a href={`/blog/${prevPost.id}/`} class="nav-link prev">
									<div class="nav-direction">← Previous</div>
									<div class="nav-content">
										{prevPost.data.heroImage && (
											<img src={prevPost.data.heroImage} alt="" class="nav-thumb" />
										)}
										<div class="nav-title">{prevPost.data.title}</div>
									</div>
								</a>
							)}
							{nextPost && (
								<a href={`/blog/${nextPost.id}/`} class="nav-link next">
									<div class="nav-direction">Next →</div>
									<div class="nav-content">
										{nextPost.data.heroImage && (
											<img src={nextPost.data.heroImage} alt="" class="nav-thumb" />
										)}
										<div class="nav-title">{nextPost.data.title}</div>
									</div>
								</a>
							)}
						</div>
					</nav>
				)}
			</article>
		</main>
		<Footer />
	</body>
</html>
